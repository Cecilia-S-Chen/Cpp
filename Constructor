#include <iostream>
using namespace std;

class Constructor {
    /*
     * 构造函数的定义：
     *  （1）定义：编译器用构造函数初始化对象
     *  （2）解释：构造函数用于“创造”对象，使对象从 无 到 有
     
     * 构造函数过程：
     * 1、开辟内存（此时内存没有清理，内存上可能有脏数据）
     * 2、给非内置类型调用默认构造函数赋初值，内置类型不赋值
     
     *  解释：内置类型不赋值：内置类型调用合成构造函数，没有初值，不赋值（没有初值的原因是为了省去赋值，提高效率）
     *      非内置类型调用默认构造函数，如果默认构造函数人为定义，有初值，则编译器必须遵循程序员的意愿给变量赋初值，否则重复内置类型步骤，不赋值
     
     * 构造函数特点：
     *  （1）特点：独有 列表初始化
     *  （2）解释：因为列表初始化是“首次”在内存上 “写数据”，只有在创造对象时，才会“首次写数据”，对象创造以后，就是“修改数据”
     
     * 构造函数分为以下几种：
     * 1、合成默认构造函数：
     *  当我们没有提供构造函数时，编译器自动生成的默认构造函数
     * 2、默认构造函数：
     *  我们提供的，没有入参的构造函数
     * 3、构造函数：
     *  我们提供入参，指定成员变量初始值的构造函数
     * 4、拷贝构造函数：
     *  （1）拷贝函数目的：用对象A “创造” 同类对象 B
     *  （2）特点：入参是同类的对象，含义是把同类对象A拷贝给同类对象B
     *  （3）易错点：拷贝构造函数的入参 一定是 引用，如果是值传递：
     *      construct( classA other) {} 等同于
     *      {
     *      classA a
     *      classA other = a; // 用a创造other时，使用了拷贝构造函数，但是此时拷贝构造函数还未完成，出现了逻辑悖论！
     *      construct (other);
     *      }
     *
     *
     *赋值函数：
     *  （1）含义：重新定义“=”作用，用入参 “修改” 数据，（数据已经存在）
     *  （2）格式：
     *      return_type operator= () {
     *      }
     */

public:
    Constructor(Constructor &other) : i(other.i), d(other.d) {

    }

    int operator=(Constructor &other) {
        i += other.i;
        d += other.d;
        return (int)(i + d);
    }

    int i;
    double d;
};
